# Copy values from here into .env.e2e.local to override the defaults used by
# `npm run dev:test` and Playwright coverage.
# If you are running the local Supabase stack, seed these values from:
# `npx supabase status -o env`
HOSTNAME=127.0.0.1
PORT=3101
PUBLIC_APP_URL=http://127.0.0.1:3101
ADMIN_APP_URL=http://127.0.0.1:3101
ASSESS_APP_URL=http://127.0.0.1:3101/assess
PARTNER_APP_URL=http://127.0.0.1:3101/partner
CLIENT_APP_URL=http://127.0.0.1:3101/client
SERVER_ACTION_ALLOWED_ORIGINS=127.0.0.1:3101,localhost:3101
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=local-dev-anon-key
SUPABASE_SERVICE_ROLE_KEY=local-dev-service-role-key
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
