# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Providers
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
# OpenRouter API key — required for real item generation (mock pipeline used when absent)
OpenRouter_API_KEY=

# App — local dev (all surfaces on one port, path-based routing)
NEXT_PUBLIC_APP_URL=http://localhost:3002
PUBLIC_APP_URL=http://localhost:3002
ASSESS_APP_URL=http://localhost:3002
ADMIN_APP_URL=http://localhost:3002
PARTNER_APP_URL=http://localhost:3002
CLIENT_APP_URL=http://localhost:3002
SERVER_ACTION_ALLOWED_ORIGINS=
# Production URLs (set these in Vercel):
# PUBLIC_APP_URL=https://trajectas.com
# ASSESS_APP_URL=https://assess.trajectas.com
# ADMIN_APP_URL=https://admin.trajectas.com
# PARTNER_APP_URL=https://partner.trajectas.com
# CLIENT_APP_URL=https://client.trajectas.com
# SERVER_ACTION_ALLOWED_ORIGINS=trajectas.com,assess.trajectas.com,admin.trajectas.com,partner.trajectas.com,client.trajectas.com
TRAJECTAS_CONTEXT_SECRET=replace-with-a-long-random-secret
# Internal API key for server-to-server calls (e.g. auto report generation)
INTERNAL_API_KEY=replace-with-a-random-hex-string
INTERNAL_INTEGRATIONS_API_ENABLED=false
INTEGRATIONS_API_SECRET_PEPPER=replace-with-a-long-random-secret
INTEGRATIONS_CONFIG_ENCRYPTION_KEY=base64-encoded-32-byte-key

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Trajectas <noreply@mail.trajectas.com>
