{
  "name": "trajectas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3002",
    "dev:test": "node scripts/testing/run-next-dev-test.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0 --ignore-pattern coverage --ignore-pattern playwright-report --ignore-pattern test-results --ignore-pattern .worktrees",
    "typecheck": "tsc --pretty false --noEmit",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:component": "vitest run tests/components",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke",
    "test:e2e:seeded": "playwright test tests/e2e/seeded",
    "test:all": "npm run test:coverage && npm run test:e2e:smoke",
    "db:push": "node scripts/db-push.mjs",
    "db:migrate": "node scripts/db-push.mjs",
    "db:status": "node scripts/db-status.mjs",
    "db:test:start": "npx supabase start",
    "db:test:env": "npx supabase status -o env",
    "db:test:reset": "npx supabase db reset --local",
    "db:test:stop": "npx supabase stop"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/helpers": "^0.3.2",
    "@dnd-kit/react": "^0.3.2",
    "@maily-to/core": "^0.3.7",
    "@maily-to/render": "^0.2.3",
    "@react-email/components": "^1.0.11",
    "@sparticuz/chromium-min": "^143.0.4",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-placeholder": "^3.22.0",
    "@tiptap/react": "^3.22.0",
    "@tiptap/starter-kit": "^3.22.0",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "isomorphic-dompurify": "^3.7.1",
    "lucide-react": "^1.6.0",
    "next": "^16.2.3",
    "next-themes": "^0.4.6",
    "openai": "^6.32.0",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "puppeteer-core": "^24.40.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.10.0",
    "sonner": "^2.0.7",
    "standardwebhooks": "^1.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
